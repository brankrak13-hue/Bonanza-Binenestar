rules_version = '2';

/**
 * BONANZA ARTE & BIENESTAR - HIGH-SECURITY RULES
 * 
 * 🛡️ SISTEMA DE PROTECCIÓN ANTIAQUEREO E INTEGRIDAD DE DATOS
 * 
 * Este conjunto de reglas implementa una arquitectura de Confianza Cero:
 * 1. Default Deny: Cualquier acceso no autorizado se bloquea de inmediato.
 * 2. Validación de Humano: App Check verifica la legitimidad de la conexión.
 * 3. Aislamiento de Identidad: Los datos sensibles solo son accesibles por el dueño del UID.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- ESCUDO GLOBAL: RECHAZAR TODO POR DEFECTO ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- FUNCIONES DE SEGURIDAD AVANZADA ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- REGLAS DE PROTECCIÓN DE DATOS POR COLECCIÓN ---

    match /roles_admin/{adminId} {
      allow read: if isAdmin();
    }

    // Perfiles: Cifrado lógico para que solo el dueño vea sus datos
    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isOwner(userProfileId) && request.resource.data.externalAuthUserId == resource.data.externalAuthUserId;
      allow delete: if isAdmin();
    }

    match /userProfiles/{userProfileId}/addresses/{addressId} {
      allow read, write: if isOwner(userProfileId) || isAdmin();
    }

    match /userProfiles/{userProfileId}/orders/{orderId} {
      allow read: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isAdmin();
      
      match /orderItems/{orderItemId} {
        allow read: if isOwner(userProfileId) || isAdmin();
        allow create: if isOwner(userProfileId);
      }
    }

    // Catálogo: Solo lectura pública, escritura bloqueada para no-admins
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if resource.data.isApproved == true || isOwner(resource.data.userProfileId) || isAdmin();
        allow create: if isSignedIn() && request.resource.data.userProfileId == request.auth.uid;
        allow update, delete: if isOwner(resource.data.userProfileId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exclusiveExperiences/{experienceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configuración del sitio: Lectura pública para imágenes personalizadas, escritura solo admin
    match /siteSettings/content/images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Seguridad de Entrada: Prevención de SPAM y ataques de inyección
    match /newsletterSubscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
