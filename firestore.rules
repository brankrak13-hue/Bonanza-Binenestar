rules_version = '2';

/**
 * BONANZA ARTE & BIENESTAR - HIGH-SECURITY RULES
 *
 * This ruleset implements a Zero-Trust architecture:
 * 1. Default Deny: Everything is blocked unless explicitly allowed.
 * 2. Identity-Based Access: Sensitive data is locked to the owner's Auth UID.
 * 3. App Check Enforcement: Prevents unauthorized API access from bots/hackers.
 * 4. Structural Segregation: Administrative data is isolated from public storefront data.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- SEGURIDAD GLOBAL: RECHAZAR POR DEFECTO ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- FUNCIONES DE VERIFICACIÓN ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- REGLAS DE COLECCIONES ---

    // Roles de administrador (Solo lectura para admins)
    match /roles_admin/{adminId} {
      allow read: if isAdmin();
    }

    // Perfiles de usuario: Blindados al dueño
    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isOwner(userProfileId) && request.resource.data.externalAuthUserId == resource.data.externalAuthUserId;
      allow delete: if isAdmin();
    }

    // Direcciones y Pedidos: Estrictamente privados
    match /userProfiles/{userProfileId}/addresses/{addressId} {
      allow read, write: if isOwner(userProfileId) || isAdmin();
    }

    match /userProfiles/{userProfileId}/orders/{orderId} {
      allow read: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isAdmin();
      
      match /orderItems/{orderItemId} {
        allow read: if isOwner(userProfileId) || isAdmin();
        allow create: if isOwner(userProfileId);
      }
    }

    // Catálogo Público: Solo lectura para el mundo, escritura solo para Admins
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if resource.data.isApproved == true || isOwner(resource.data.userProfileId) || isAdmin();
        allow create: if isSignedIn() && request.resource.data.userProfileId == request.auth.uid;
        allow update, delete: if isOwner(resource.data.userProfileId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exclusiveExperiences/{experienceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Suscriptores y Contacto: Blindaje de escritura (Cualquiera puede escribir, nadie puede leer excepto Admin)
    match /newsletterSubscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
