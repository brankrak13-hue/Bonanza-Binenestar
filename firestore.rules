rules_version = '2';

/**
 * BONANZA ARTE & BIENESTAR - RULES V2
 * 
 * 🛡️ SISTEMA DE PROTECCIÓN E INTEGRIDAD DE DATOS
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- ESCUDO GLOBAL: RECHAZAR TODO POR DEFECTO ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- FUNCIONES DE SEGURIDAD ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- REGLAS POR COLECCIÓN ---

    // Administración: Permitir a los usuarios crear su propio registro (para el flujo de la llave secreta)
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow create: if isOwner(adminId);
      allow update, delete: if isAdmin();
    }

    // Perfiles
    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isOwner(userProfileId);
      allow delete: if isAdmin();
    }

    match /userProfiles/{userProfileId}/addresses/{addressId} {
      allow read, write: if isOwner(userProfileId) || isAdmin();
    }

    match /userProfiles/{userProfileId}/orders/{orderId} {
      allow read: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isAdmin();
      
      match /orderItems/{orderItemId} {
        allow read: if isOwner(userProfileId) || isAdmin();
        allow create: if isOwner(userProfileId);
      }
    }

    // Catálogo público
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if resource.data.isApproved == true || isOwner(resource.data.userProfileId) || isAdmin();
        allow create: if isSignedIn() && request.resource.data.userProfileId == request.auth.uid;
        allow update, delete: if isOwner(resource.data.userProfileId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configuración del sitio (Imágenes personalizadas)
    // Importante: Permitir lectura pública para que todos vean las imágenes cambiadas
    match /siteSettings/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exclusiveExperiences/{experienceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /newsletterSubscribers/{subscriberId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}